PUBLIC	_GetShiftUpThresholds
; Function compile flags: /Odtp /RTCsu /ZI
;	COMDAT _GetShiftUpThresholds
_TEXT	SEGMENT
_intBW$ = 8						; size = 4
_GetShiftUpThresholds PROC				; COMDAT

; 666  : {

  00000	55		 push	 ebp
  00001	8b ec		 mov	 ebp, esp
  00003	81 ec c0 00 00
	00		 sub	 esp, 192		; 000000c0H
  00009	53		 push	 ebx
  0000a	56		 push	 esi
  0000b	57		 push	 edi
  0000c	8d bd 40 ff ff
	ff		 lea	 edi, DWORD PTR [ebp-192]
  00012	b9 30 00 00 00	 mov	 ecx, 48			; 00000030H
  00017	b8 cc cc cc cc	 mov	 eax, -858993460		; ccccccccH
  0001c	f3 ab		 rep stosd

; 667  : 	//' Initial values determined by finding the following process: (all using Pink Gaussian Noise channel 0 to 3 KHz) 
; 668  : 	//'       1) Find Min S:N that will give reliable (at least 4/5 tries) decoding at the fastest mode for the bandwidth.
; 669  : 	//'       2) At that SAME S:N use the next fastest (more robust mode for the bandwidth)
; 670  : 	//'       3) Over several frames average the Quality of the decoded frame in 2) above That quality value is the one that
; 671  : 	//'       is then used as the shift up threshold for that mode. (note the top mode will never use a value to shift up).
; 672  : 	//'       This might be adjusted some but should along with a requirement for two successive ACKs make a good algorithm
; 673  : 
; 674  : 	if (intBW == 200)

  0001e	81 7d 08 c8 00
	00 00		 cmp	 DWORD PTR _intBW$[ebp], 200 ; 000000c8H
  00025	75 07		 jne	 SHORT $LN5@GetShiftUp

; 675  : 		return byt200;

  00027	b8 00 00 00 00	 mov	 eax, OFFSET _byt200
  0002c	eb 40		 jmp	 SHORT $LN6@GetShiftUp
$LN5@GetShiftUp:

; 676  : 
; 677  : 	if (intBW == 500) 

  0002e	81 7d 08 f4 01
	00 00		 cmp	 DWORD PTR _intBW$[ebp], 500 ; 000001f4H
  00035	75 07		 jne	 SHORT $LN4@GetShiftUp

; 678  : 		return byt500;

  00037	b8 00 00 00 00	 mov	 eax, OFFSET _byt500
  0003c	eb 30		 jmp	 SHORT $LN6@GetShiftUp
$LN4@GetShiftUp:

; 679  : 
; 680  : 	if (intBW == 1000) 

  0003e	81 7d 08 e8 03
	00 00		 cmp	 DWORD PTR _intBW$[ebp], 1000 ; 000003e8H
  00045	75 07		 jne	 SHORT $LN3@GetShiftUp

; 681  : 		return byt1000;

  00047	b8 00 00 00 00	 mov	 eax, OFFSET _byt1000
  0004c	eb 20		 jmp	 SHORT $LN6@GetShiftUp
$LN3@GetShiftUp:

; 682  : 
; 683  : 	// default to 2000
; 684  : 
; 685  : 	if (TuningRange > 0  && !Use600Modes)

  0004e	83 3d 00 00 00
	00 00		 cmp	 DWORD PTR _TuningRange, 0
  00055	7e 12		 jle	 SHORT $LN2@GetShiftUp
  00057	83 3d 00 00 00
	00 00		 cmp	 DWORD PTR _Use600Modes, 0
  0005e	75 09		 jne	 SHORT $LN2@GetShiftUp

; 686  : 		return byt2000;

  00060	b8 00 00 00 00	 mov	 eax, OFFSET _byt2000
  00065	eb 07		 jmp	 SHORT $LN6@GetShiftUp

; 687  : 	else

  00067	eb 05		 jmp	 SHORT $LN6@GetShiftUp
$LN2@GetShiftUp:

; 688  : 		return byt2000FM;

  00069	b8 00 00 00 00	 mov	 eax, OFFSET _byt2000FM
$LN6@GetShiftUp:

; 689  : }

  0006e	5f		 pop	 edi
