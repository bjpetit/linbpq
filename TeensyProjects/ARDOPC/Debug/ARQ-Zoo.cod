PUBLIC	_SendARQConnectRequest
EXTRN	_EncodeARQConRequest:PROC
; Function compile flags: /Odtp /RTCsu /ZI
;	COMDAT _SendARQConnectRequest
_TEXT	SEGMENT
_strMycall$ = 8						; size = 4
_strTargetCall$ = 12					; size = 4
_SendARQConnectRequest PROC				; COMDAT

; 1856 : {

  00000	55		 push	 ebp
  00001	8b ec		 mov	 ebp, esp
  00003	81 ec c0 00 00
	00		 sub	 esp, 192		; 000000c0H
  00009	53		 push	 ebx
  0000a	56		 push	 esi
  0000b	57		 push	 edi
  0000c	8d bd 40 ff ff
	ff		 lea	 edi, DWORD PTR [ebp-192]
  00012	b9 30 00 00 00	 mov	 ecx, 48			; 00000030H
  00017	b8 cc cc cc cc	 mov	 eax, -858993460		; ccccccccH
  0001c	f3 ab		 rep stosd

; 1857 : 	// Psuedo Code:
; 1858 : 	//  Determine the proper bandwidth and target call
; 1859 : 	//  Go to the ISS State and ISSConREq sub state
; 1860 : 	//  Encode the connect frame with extended Leader
; 1861 : 	//  initialize the ConReqCount and set the Frame repeat interval
; 1862 : 	//  (Handles protocol rule 1.1) 
; 1863 : 
; 1864 : 	InitializeConnection();

  0001e	e8 00 00 00 00	 call	 _InitializeConnection

; 1865 : 	intRmtLeaderMeas = 0;

  00023	c7 05 00 00 00
	00 00 00 00 00	 mov	 DWORD PTR _intRmtLeaderMeas, 0

; 1866 : 	strcpy(strRemoteCallsign, strTargetCall);

  0002d	8b 45 0c	 mov	 eax, DWORD PTR _strTargetCall$[ebp]
  00030	50		 push	 eax
  00031	68 00 00 00 00	 push	 OFFSET _strRemoteCallsign
  00036	e8 00 00 00 00	 call	 _strcpy
  0003b	83 c4 08	 add	 esp, 8

; 1867 : 	strcpy(strLocalCallsign, strMycall);

  0003e	8b 45 08	 mov	 eax, DWORD PTR _strMycall$[ebp]
  00041	50		 push	 eax
  00042	68 00 00 00 00	 push	 OFFSET _strLocalCallsign
  00047	e8 00 00 00 00	 call	 _strcpy
  0004c	83 c4 08	 add	 esp, 8

; 1868 : 	strcpy(strFinalIDCallsign, strLocalCallsign);

  0004f	68 00 00 00 00	 push	 OFFSET _strLocalCallsign
  00054	68 00 00 00 00	 push	 OFFSET _strFinalIDCallsign
  00059	e8 00 00 00 00	 call	 _strcpy
  0005e	83 c4 08	 add	 esp, 8

; 1869 : 
; 1870 : 	EncLen = EncodeARQConRequest(strMycall, strTargetCall, ARQBandwidth, bytEncodedBytes);

  00061	68 00 00 00 00	 push	 OFFSET _bytEncodedBytes
  00066	a1 00 00 00 00	 mov	 eax, DWORD PTR _ARQBandwidth
  0006b	50		 push	 eax
  0006c	8b 4d 0c	 mov	 ecx, DWORD PTR _strTargetCall$[ebp]
  0006f	51		 push	 ecx
  00070	8b 55 08	 mov	 edx, DWORD PTR _strMycall$[ebp]
  00073	52		 push	 edx
  00074	e8 00 00 00 00	 call	 _EncodeARQConRequest
  00079	83 c4 10	 add	 esp, 16			; 00000010H
  0007c	a3 00 00 00 00	 mov	 DWORD PTR _EncLen, eax

; 1871 : 
; 1872 : 	if (EncLen == 0)

  00081	83 3d 00 00 00
	00 00		 cmp	 DWORD PTR _EncLen, 0
  00088	75 07		 jne	 SHORT $LN1@SendARQCon

; 1873 : 		return FALSE;

  0008a	33 c0		 xor	 eax, eax
  0008c	e9 ae 00 00 00	 jmp	 $LN2@SendARQCon
$LN1@SendARQCon:

; 1874 : 	
; 1875 : 	// generate the modulation with 2 x the default FEC leader length...Should insure reception at the target
; 1876 : 	// Note this is sent with session ID 0xFF
; 1877 : 
; 1878 : 	//	Set all flags before playing, as the End TX is called before we return here
; 1879 : 	blnAbort = FALSE;

  00091	c7 05 00 00 00
	00 00 00 00 00	 mov	 DWORD PTR _blnAbort, 0

; 1880 : 	dttTimeoutTrip = Now;

  0009b	e8 00 00 00 00	 call	 _getTicks
  000a0	a3 00 00 00 00	 mov	 DWORD PTR _dttTimeoutTrip, eax

; 1881 : 	SetARDOPProtocolState(ISS);

  000a5	6a 02		 push	 2
  000a7	e8 00 00 00 00	 call	 _SetARDOPProtocolState
  000ac	83 c4 04	 add	 esp, 4

; 1882 : 	ARQState = ISSConReq;    

  000af	c7 05 00 00 00
	00 01 00 00 00	 mov	 DWORD PTR _ARQState, 1

; 1883 : 	intRepeatCount = 1;

  000b9	c7 05 00 00 00
	00 01 00 00 00	 mov	 DWORD PTR _intRepeatCount, 1

; 1884 : 
; 1885 : 	displayCall(0x7E, strTargetCall);

  000c3	8b 45 0c	 mov	 eax, DWORD PTR _strTargetCall$[ebp]
  000c6	50		 push	 eax
  000c7	6a 7e		 push	 126			; 0000007eH
  000c9	e8 00 00 00 00	 call	 _displayCall
  000ce	83 c4 08	 add	 esp, 8

; 1886 : 	
; 1887 : 	bytSessionID = GenerateSessionID(strMycall, strTargetCall);  // Now set bytSessionID to receive ConAck (note the calling staton is the first entry in GenerateSessionID) 

  000d1	8b 45 0c	 mov	 eax, DWORD PTR _strTargetCall$[ebp]
  000d4	50		 push	 eax
  000d5	8b 4d 08	 mov	 ecx, DWORD PTR _strMycall$[ebp]
  000d8	51		 push	 ecx
  000d9	e8 00 00 00 00	 call	 _GenerateSessionID
  000de	83 c4 08	 add	 esp, 8
  000e1	a2 00 00 00 00	 mov	 BYTE PTR _bytSessionID, al

; 1888 : 	bytPendingSessionID = bytSessionID;

  000e6	a0 00 00 00 00	 mov	 al, BYTE PTR _bytSessionID
  000eb	a2 00 00 00 00	 mov	 BYTE PTR _bytPendingSessionID, al

; 1889 : 
; 1890 : 	//Logs.WriteDebug("[SendARQConnectRequest] strMycall=" & strMycall & "  strTargetCall=" & strTargetCall & "  bytPendnigSessionID=" & Format(bytPendingSessionID, "X"))
; 1891 : 	
; 1892 : 	blnPending = TRUE;

  000f0	c7 05 00 00 00
	00 01 00 00 00	 mov	 DWORD PTR _blnPending, 1

; 1893 : 	blnARQConnected = FALSE;

  000fa	c7 05 00 00 00
	00 00 00 00 00	 mov	 DWORD PTR _blnARQConnected, 0

; 1894 : 	
; 1895 : 	intFrameRepeatInterval = 2000;  // ms ' Finn reported 7/4/2015 that 1600 was too short ...need further evaluation but temporarily moved to 2000 ms

  00104	c7 05 00 00 00
	00 d0 07 00 00	 mov	 DWORD PTR _intFrameRepeatInterval, 2000 ; 000007d0H

; 1896 : 	blnEnbARQRpt = TRUE;

  0010e	c7 05 00 00 00
	00 01 00 00 00	 mov	 DWORD PTR _blnEnbARQRpt, 1

; 1897 : 
; 1898 : 	Mod4FSKDataAndPlay(bytEncodedBytes[0], &bytEncodedBytes[0], EncLen, LeaderLength);		// only returns when all sent

  00118	a1 00 00 00 00	 mov	 eax, DWORD PTR _LeaderLength
  0011d	50		 push	 eax
  0011e	8b 0d 00 00 00
	00		 mov	 ecx, DWORD PTR _EncLen
  00124	51		 push	 ecx
  00125	68 00 00 00 00	 push	 OFFSET _bytEncodedBytes
  0012a	0f b6 15 00 00
	00 00		 movzx	 edx, BYTE PTR _bytEncodedBytes
  00131	52		 push	 edx
  00132	e8 00 00 00 00	 call	 _Mod4FSKDataAndPlay
  00137	83 c4 10	 add	 esp, 16			; 00000010H

; 1899 : 
; 1900 : 	//' Update the main form menu status lable 
; 1901 :     //        Dim stcStatus As Status = Nothing
; 1902 :     //        stcStatus.ControlName = "mnuBusy"
; 1903 :     //        stcStatus.Text = "Calling " & strTargetCall
; 1904 :     //        queTNCStatus.Enqueue(stcStatus)
; 1905 : 
; 1906 : 	return TRUE;

  0013a	b8 01 00 00 00	 mov	 eax, 1
$LN2@SendARQCon:

; 1907 : }

  0013f	5f		 pop	 edi
  00140	5e		 pop	 esi
  00141	5b		 pop	 ebx
  00142	81 c4 c0 00 00
	00		 add	 esp, 192		; 000000c0H
  00148	3b ec		 cmp	 ebp, esp
  0014a	e8 00 00 00 00	 call	 __RTC_CheckEsp
  0014f	8b e5		 mov	 esp, ebp
  00151	5d		 pop	 ebp
  00152	c3		 ret	 0
_SendARQConnectRequest ENDP
; Function compile flags: /Odtp /RTCsu /ZI
_TEXT	ENDS
;	COMDAT _Send10MinID
_TEXT	SEGMENT
_dttSafetyBailout$ = -8					; size = 4
_Send10MinID PROC					; COMDAT

; 1913 : {

  00000	55		 push	 ebp
  00001	8b ec		 mov	 ebp, esp
  00003	81 ec cc 00 00
	00		 sub	 esp, 204		; 000000ccH
  00009	53		 push	 ebx
  0000a	56		 push	 esi
  0000b	57		 push	 edi
  0000c	8d bd 34 ff ff
	ff		 lea	 edi, DWORD PTR [ebp-204]
  00012	b9 33 00 00 00	 mov	 ecx, 51			; 00000033H
  00017	b8 cc cc cc cc	 mov	 eax, -858993460		; ccccccccH
  0001c	f3 ab		 rep stosd

; 1914 : 	int dttSafetyBailout = 40;	// 100 mS intervals

  0001e	c7 45 f8 28 00
	00 00		 mov	 DWORD PTR _dttSafetyBailout$[ebp], 40 ; 00000028H

; 1915 : 
; 1916 : 	if (Now - dttLastFECIDSent > 600000 && !blnDISCRepeating)

  00025	e8 00 00 00 00	 call	 _getTicks
  0002a	2b 05 00 00 00
	00		 sub	 eax, DWORD PTR _dttLastFECIDSent
  00030	3d c0 27 09 00	 cmp	 eax, 600000		; 000927c0H
  00035	76 53		 jbe	 SHORT $LN1@Send10MinI
  00037	83 3d 00 00 00
	00 00		 cmp	 DWORD PTR _blnDISCRepeating, 0
  0003e	75 4a		 jne	 SHORT $LN1@Send10MinI

; 1917 : 	{
; 1918 : 
; 1919 : 		// if (DebugLog) Debugprintf(("[ARDOPptocol.Send10MinID] Send ID Frame")
; 1920 : 		// Send an ID frame (Handles protocol rule 4.0)
; 1921 : 
; 1922 : 		blnEnbARQRpt = FALSE;

  00040	c7 05 00 00 00
	00 00 00 00 00	 mov	 DWORD PTR _blnEnbARQRpt, 0

; 1923 : 
; 1924 : 		dttLastFECIDSent = Now;

  0004a	e8 00 00 00 00	 call	 _getTicks
  0004f	a3 00 00 00 00	 mov	 DWORD PTR _dttLastFECIDSent, eax

; 1925 : 		EncLen = Encode4FSKIDFrame(strLocalCallsign, GridSquare, bytEncodedBytes);

  00054	68 00 00 00 00	 push	 OFFSET _bytEncodedBytes
  00059	68 00 00 00 00	 push	 OFFSET _GridSquare
  0005e	68 00 00 00 00	 push	 OFFSET _strLocalCallsign
  00063	e8 00 00 00 00	 call	 _Encode4FSKIDFrame
  00068	83 c4 0c	 add	 esp, 12			; 0000000cH
  0006b	a3 00 00 00 00	 mov	 DWORD PTR _EncLen, eax

; 1926 : 		Mod4FSKDataAndPlay(0x30, &bytEncodedBytes[0], 16, 0);		// only returns when all sent		

  00070	6a 00		 push	 0
  00072	6a 10		 push	 16			; 00000010H
  00074	68 00 00 00 00	 push	 OFFSET _bytEncodedBytes
  00079	6a 30		 push	 48			; 00000030H
  0007b	e8 00 00 00 00	 call	 _Mod4FSKDataAndPlay
  00080	83 c4 10	 add	 esp, 16			; 00000010H

; 1927 : 		return TRUE;

  00083	b8 01 00 00 00	 mov	 eax, 1
  00088	eb 02		 jmp	 SHORT $LN2@Send10MinI
$LN1@Send10MinI:

; 1928 : 	}
; 1929 : 	return FALSE;

  0008a	33 c0		 xor	 eax, eax
$LN2@Send10MinI:

; 1930 : }

  0008c	5f		 pop	 edi
  0008d	5e		 pop	 esi
  0008e	5b		 pop	 ebx
  0008f	81 c4 cc 00 00
	00		 add	 esp, 204		; 000000ccH
  00095	3b ec		 cmp	 ebp, esp
  00097	e8 00 00 00 00	 call	 __RTC_CheckEsp
