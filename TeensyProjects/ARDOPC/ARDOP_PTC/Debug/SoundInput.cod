  00017	b8 cc cc cc cc	 mov	 eax, -858993460		; ccccccccH
  0001c	f3 ab		 rep stosd

; 3723 : 	//	Subroutine to update bmpConstellation plot for 8FSK modes...
; 3724 : /*
; 3725 :             Dim dblRad As Double = 0
; 3726 :             Dim intToneSum As Int32 = 0
; 3727 :             Dim intMagMax As Double = 0
; 3728 :             Dim dblAng As Double
; 3729 :             Dim dblDistanceSum As Double
; 3730 :             Dim dblPlotRotation As Double = 0
; 3731 :             Dim stcStatus As Status
; 3732 :             Dim yCenter, xCenter As Integer
; 3733 :             Dim intRad As Int32
; 3734 :             Dim clrPixel As System.Drawing.Color
; 3735 :             Dim intJatMaxMag As Int32
; 3736 :             bmpConstellation = New Bitmap(89, 89)
; 3737 :             ' Draw the axis and paint the black background area
; 3738 :             yCenter = (bmpConstellation.Height - 2) \ 2
; 3739 :             xCenter = (bmpConstellation.Width - 2) \ 2
; 3740 :             For x As Integer = 0 To bmpConstellation.Width - 1
; 3741 :                 For y As Integer = 0 To bmpConstellation.Height - 1
; 3742 :                     If y = yCenter Or x = xCenter Then
; 3743 :                         bmpConstellation.SetPixel(x, y, Color.DeepSkyBlue)
; 3744 :                     End If
; 3745 :                 Next y
; 3746 :             Next x
; 3747 :             For i As Integer = 0 To (intToneMags.Length - 1) Step 8  ' for the number of symbols represented by intToneMags
; 3748 :                 intToneSum = 0
; 3749 :                 intMagMax = 0
; 3750 :                 For j As Integer = 0 To 7
; 3751 :                     If intToneMags(i + j) > intMagMax Then
; 3752 :                         intMagMax = intToneMags(i + j)
; 3753 :                         intJatMaxMag = j
; 3754 :                     End If
; 3755 :                     intToneSum += intToneMags(i + j)
; 3756 :                 Next j
; 3757 :                 intRad = Max(5, 42 - 40 * (intToneSum - intMagMax) / intToneSum)
; 3758 :                 If intRad < 15 Then
; 3759 :                     clrPixel = Color.Tomato
; 3760 :                 ElseIf intRad < 30 Then
; 3761 :                     clrPixel = Color.Gold
; 3762 :                 Else
; 3763 :                     clrPixel = Color.Lime
; 3764 :                 End If
; 3765 :                 ' plot the symbols rotated to avoid the axis
; 3766 :                 dblAng = PI / 9 + (intJatMaxMag * PI / 4)
; 3767 :                 bmpConstellation.SetPixel(CInt(xCenter + intRad * Cos(dblAng)), CInt(yCenter + intRad * Sin(dblAng)), clrPixel)
; 3768 :                 dblDistanceSum += (43 - intRad)
; 3769 :             Next i
; 3770 :             intQuality = Math.Max(0, CInt(100 - 2.0 * (dblDistanceSum / (intToneMags.Length \ 8)))) ' factor 2.0 emperically chosen for calibration (Qual range 25 to 100)
; 3771 :             stcStatus.ControlName = "lblQuality"
; 3772 :             stcStatus.Text = "8FSK Quality: " & intQuality.ToString
; 3773 :             queTNCStatus.Enqueue(stcStatus)
; 3774 :             If MCB.AccumulateStats Then
; 3775 :                 stcQualityStats.int8FSKQualityCnts += 1
; 3776 :                 stcQualityStats.int8FSKQuality += intQuality
; 3777 :             End If
; 3778 :             stcStatus.ControlName = "ConstellationPlot"
; 3779 :             queTNCStatus.Enqueue(stcStatus)
; 3780 :         Catch ex As Exception
; 3781 :             Logs.Exception("[Main.Update8FSKConstellation] Err: " & ex.ToString)
; 3782 :         End Try
; 3783 :     End Sub ' Update8FSKConstellation
; 3784 : 	*/
; 3785 : 	return;
; 3786 : 
; 3787 : }

  0001e	5f		 pop	 edi
  0001f	5e		 pop	 esi
  00020	5b		 pop	 ebx
  00021	8b e5		 mov	 esp, ebp
  00023	5d		 pop	 ebp
  00024	c3		 ret	 0
_Update8FSKConstellation ENDP
