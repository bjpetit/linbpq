  00017	b8 cc cc cc cc	 mov	 eax, -858993460		; ccccccccH
  0001c	f3 ab		 rep stosd

; 3797 : 	//	Subroutine to update bmpConstellation plot for 8FSK modes...
; 3798 : /*
; 3799 :             Dim dblRad As Double = 0
; 3800 :             Dim intToneSum As Int32 = 0
; 3801 :             Dim intMagMax As Double = 0
; 3802 :             Dim dblAng As Double
; 3803 :             Dim dblDistanceSum As Double
; 3804 :             Dim dblPlotRotation As Double = 0
; 3805 :             Dim stcStatus As Status
; 3806 :             Dim yCenter, xCenter As Integer
; 3807 :             Dim intRad As Int32
; 3808 :             Dim clrPixel As System.Drawing.Color
; 3809 :             Dim intJatMaxMag As Int32
; 3810 :             bmpConstellation = New Bitmap(89, 89)
; 3811 :             ' Draw the axis and paint the black background area
; 3812 :             yCenter = (bmpConstellation.Height - 2) \ 2
; 3813 :             xCenter = (bmpConstellation.Width - 2) \ 2
; 3814 :             For x As Integer = 0 To bmpConstellation.Width - 1
; 3815 :                 For y As Integer = 0 To bmpConstellation.Height - 1
; 3816 :                     If y = yCenter Or x = xCenter Then
; 3817 :                         bmpConstellation.SetPixel(x, y, Color.DeepSkyBlue)
; 3818 :                     End If
; 3819 :                 Next y
; 3820 :             Next x
; 3821 :             For i As Integer = 0 To (intToneMags.Length - 1) Step 8  ' for the number of symbols represented by intToneMags
; 3822 :                 intToneSum = 0
; 3823 :                 intMagMax = 0
; 3824 :                 For j As Integer = 0 To 7
; 3825 :                     If intToneMags(i + j) > intMagMax Then
; 3826 :                         intMagMax = intToneMags(i + j)
; 3827 :                         intJatMaxMag = j
; 3828 :                     End If
; 3829 :                     intToneSum += intToneMags(i + j)
; 3830 :                 Next j
; 3831 :                 intRad = Max(5, 42 - 40 * (intToneSum - intMagMax) / intToneSum)
; 3832 :                 If intRad < 15 Then
; 3833 :                     clrPixel = Color.Tomato
; 3834 :                 ElseIf intRad < 30 Then
; 3835 :                     clrPixel = Color.Gold
; 3836 :                 Else
; 3837 :                     clrPixel = Color.Lime
; 3838 :                 End If
; 3839 :                 ' plot the symbols rotated to avoid the axis
; 3840 :                 dblAng = PI / 9 + (intJatMaxMag * PI / 4)
; 3841 :                 bmpConstellation.SetPixel(CInt(xCenter + intRad * Cos(dblAng)), CInt(yCenter + intRad * Sin(dblAng)), clrPixel)
; 3842 :                 dblDistanceSum += (43 - intRad)
; 3843 :             Next i
; 3844 :             intQuality = Math.Max(0, CInt(100 - 2.0 * (dblDistanceSum / (intToneMags.Length \ 8)))) ' factor 2.0 emperically chosen for calibration (Qual range 25 to 100)
; 3845 :             stcStatus.ControlName = "lblQuality"
; 3846 :             stcStatus.Text = "8FSK Quality: " & intQuality.ToString
; 3847 :             queTNCStatus.Enqueue(stcStatus)
; 3848 :             If MCB.AccumulateStats Then
; 3849 :                 stcQualityStats.int8FSKQualityCnts += 1
; 3850 :                 stcQualityStats.int8FSKQuality += intQuality
; 3851 :             End If
; 3852 :             stcStatus.ControlName = "ConstellationPlot"
; 3853 :             queTNCStatus.Enqueue(stcStatus)
; 3854 :         Catch ex As Exception
; 3855 :             Logs.Exception("[Main.Update8FSKConstellation] Err: " & ex.ToString)
; 3856 :         End Try
; 3857 :     End Sub ' Update8FSKConstellation
; 3858 : 	*/
; 3859 : 	return;
; 3860 : 
; 3861 : }

