//
// Dialog
//

AGWCONNWINDOW DIALOGEX 17, 37, 200, 205
STYLE DS_MODALFRAME | DS_3DLOOK | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX
CLASS "AGWCONNWINDOW"
CAPTION "AGWtoBPQ Connections"
