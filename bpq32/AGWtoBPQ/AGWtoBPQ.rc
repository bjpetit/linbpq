BEGIN
    LTEXT           "Sess Host              Port Callsign",300,5,3,190,8
	LISTBOX         IDC_CONNECTIONS_LIST,2,12,195,175,NOT WS_TABSTOP | WS_VSCROLL
END

#include "config.rc"

AGWMAINWINDOW DIALOGEX FIXED IMPURE  100, 100, 273, 215
STYLE DS_MODALFRAME | DS_3DLOOK | WS_POPUPWINDOW | WS_DLGFRAME | WS_MINIMIZEBOX | WS_SIZEBOX
CLASS "AGWMAINWINDOW"
MENU MENU_1
CAPTION "AGWtoBPQ Version 1.2.1"
FONT 8, "FixedSys"
BEGIN
	CONTROL "",1004, "LISTBOX", LBS_NOTIFY | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_VSCROLL, 2, 2, 269, 220
END



MENU_1 MENU
BEGIN
   MENUITEM "Config" 1008
   MENUITEM "Show Connections"	1009
END






